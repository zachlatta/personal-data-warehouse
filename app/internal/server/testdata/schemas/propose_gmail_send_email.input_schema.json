      "items": {
        "type": "string"
      },
      "type": [
        "null",
        "array"
      ]
    },
    "body_html": {
      "description": "optional HTML email body",
      "type": "string"
    },
    "body_text": {
      "description": "plain-text email body",
      "type": "string"
    },
    "cc": {
      "description": "carbon-copy recipients",
      "items": {
        "type": "string"
      },
      "type": [
        "null",
        "array"
      ]
    },
    "context": {
