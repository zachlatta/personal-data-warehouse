{
  "additionalProperties": false,
  "properties": {
    "context": {
      "additionalProperties": true,
      "description": "optional source context for human review",
      "type": "object"
    },
    "mutations": {
      "description": "one or more mutation objects",
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "type": [
        "null",
        "array"
      ]
    },
    "reason": {
