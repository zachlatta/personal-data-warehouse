#!/bin/zsh
set -u

LABEL="com.zachlatta.personal-data-warehouse.apple-notes-upload"
LOG_DIR="$HOME/Library/Logs/personal-data-warehouse"
RUN_LOG="$LOG_DIR/apple-notes-upload.run.log"
HEARTBEAT_FILE="$LOG_DIR/apple-notes-upload.heartbeat"

echo "LaunchAgent:"
launchctl print "gui/$(id -u)/$LABEL" | sed -n '1,45p'

echo
. "$(cd "$(dirname "$0")" && pwd)/_pdw-upload-lib.sh"
pdw_print_health "$HEARTBEAT_FILE"

echo
echo "Recent run log:"
if [[ -f "$RUN_LOG" ]]; then
  tail -40 "$RUN_LOG"
else
  echo "missing: $RUN_LOG"
fi
