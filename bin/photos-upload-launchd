#!/bin/zsh
set -u

REPO_DIR="/Users/zrl/dev/zachlatta/personal-data-warehouse"
UV="/opt/homebrew/bin/uv"
# Run the Python uploader module DIRECTLY (not through `pdw ingest`): pdw
# self-updates on every release, and each binary replacement invalidates the
# TCC grants attributed to it — first Full Disk Access, then the
# kTCCServicePhotos grant this uploader relies on. With pdw out of the exec
# chain, macOS attributes the Photos-library permission to the stable
# binaries (zsh / uv / the venv python), so one approval survives releases.
# Credentials still come from pdw's own config file, so `pdw login` remains
# the single setup step.
PDW_CONFIG="$HOME/.config/pdw/config.json"
if [ -r "$PDW_CONFIG" ]; then
  export PDW_API_URL="${PDW_API_URL:-$(/usr/bin/python3 -c 'import json,sys;print(json.load(open(sys.argv[1]))["base_url"])' "$PDW_CONFIG" 2>/dev/null)}"
  export PDW_SECRET_TOKEN="${PDW_SECRET_TOKEN:-$(/usr/bin/python3 -c 'import json,sys;print(json.load(open(sys.argv[1]))["token"])' "$PDW_CONFIG" 2>/dev/null)}"
fi
LOG_DIR="$HOME/Library/Logs/personal-data-warehouse"
LOG_FILE="$LOG_DIR/photos-upload.run.log"
HEARTBEAT_FILE="$LOG_DIR/photos-upload.heartbeat"

mkdir -p "$LOG_DIR"

started_at_epoch="$(date +%s)"
started_at_iso="$(date -Iseconds)"

echo "[$started_at_iso] starting photos upload" >> "$LOG_FILE"

if ! cd "$REPO_DIR"; then
  exit_code=1
  echo "[$(date -Iseconds)] failed to cd to $REPO_DIR" >> "$LOG_FILE"
else
  "$UV" run python -m personal_data_warehouse_photos.cli --mode incremental >> "$LOG_FILE" 2>&1
  exit_code=$?
fi

finished_at_epoch="$(date +%s)"
finished_at_iso="$(date -Iseconds)"
duration_seconds="$((finished_at_epoch - started_at_epoch))"

. "$REPO_DIR/bin/_pdw-upload-lib.sh"
pdw_record_run "$HEARTBEAT_FILE" "$finished_at_iso" "$exit_code"
echo "[$finished_at_iso] finished photos upload exit_code=$exit_code duration_seconds=$duration_seconds" >> "$LOG_FILE"

exit "$exit_code"
