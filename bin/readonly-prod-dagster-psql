#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: bin/readonly-prod-dagster-psql 'select ...'
       echo 'select ...' | bin/readonly-prod-dagster-psql
EOF
}

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

if [[ $# -gt 0 ]]; then
  sql="$*"
elif [[ ! -t 0 ]]; then
  sql="$(cat)"
else
  usage
  exit 2
fi

if [[ -z "${sql//[[:space:]]/}" ]]; then
  usage
  exit 2
fi

url="$(
  uv run python - <<'PY'
import os
import sys

from dotenv import dotenv_values

value = os.environ.get("PROD_DAGSTER_URL") or dotenv_values(".env").get("PROD_DAGSTER_URL")
if not value:
    print("PROD_DAGSTER_URL must be set in the environment or .env", file=sys.stderr)
    raise SystemExit(1)

print(value)
PY
)"

PGOPTIONS="${PGOPTIONS:+$PGOPTIONS }-c default_transaction_read_only=on" \
  psql "$url" \
  --no-psqlrc \
  --set=ON_ERROR_STOP=1 \
  --command="$sql"
