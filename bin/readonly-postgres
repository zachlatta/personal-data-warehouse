#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: bin/readonly-postgres 'select ...'
       echo 'select ...' | bin/readonly-postgres
EOF
}

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

if [[ $# -gt 0 ]]; then
  sql="$*"
elif [[ ! -t 0 ]]; then
  sql="$(cat)"
else
  usage
  exit 2
fi

if [[ -z "${sql//[[:space:]]/}" ]]; then
  usage
  exit 2
fi

uv run python - "$sql" <<'PY'
from __future__ import annotations

import csv
import os
import sys

from dotenv import load_dotenv

from personal_data_warehouse.postgres import PostgresWarehouse
from personal_data_warehouse.postgres_readonly import PostgresReadOnlyRunner, csv_value


load_dotenv(".env")
postgres_database_url = os.environ.get("POSTGRES_DATABASE_URL")
if not postgres_database_url:
    print("POSTGRES_DATABASE_URL must be set in the environment or .env", file=sys.stderr)
    raise SystemExit(1)

sql = sys.argv[1]
warehouse = PostgresWarehouse(postgres_database_url)
result = PostgresReadOnlyRunner(warehouse).query(sql, max_rows=0)
writer = csv.writer(sys.stdout, delimiter="\t", lineterminator="\n")
if result.columns:
    writer.writerow(result.columns)
for row in result.rows:
    writer.writerow([csv_value(row.get(column)) for column in result.columns])
PY
