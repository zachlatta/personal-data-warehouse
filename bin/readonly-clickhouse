#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: bin/readonly-clickhouse 'select ...'
       echo 'select ...' | bin/readonly-clickhouse
EOF
}

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

if [[ $# -gt 0 ]]; then
  sql="$*"
elif [[ ! -t 0 ]]; then
  sql="$(cat)"
else
  usage
  exit 2
fi

if [[ -z "${sql//[[:space:]]/}" ]]; then
  usage
  exit 2
fi

uv run python - "$sql" <<'PY'
from __future__ import annotations

import csv
import os
import sys

from dotenv import load_dotenv

from personal_data_warehouse.clickhouse import ClickHouseWarehouse
from personal_data_warehouse.clickhouse_readonly import ClickHouseReadOnlyRunner, csv_value


load_dotenv(".env")
clickhouse_url = os.environ.get("CLICKHOUSE_URL")
if not clickhouse_url:
    print("CLICKHOUSE_URL must be set in the environment or .env", file=sys.stderr)
    raise SystemExit(1)

sql = sys.argv[1]
warehouse = ClickHouseWarehouse(clickhouse_url)
result = ClickHouseReadOnlyRunner(warehouse).query(sql, max_rows=0)
writer = csv.writer(sys.stdout, delimiter="\t", lineterminator="\n")
if result.columns:
    writer.writerow(result.columns)
for row in result.rows:
    writer.writerow([csv_value(row.get(column)) for column in result.columns])
PY
